{
  "name": "claude-switcher",
  "displayName": "Claude Switcher",
  "description": "Browse and resume Claude Code conversations from VS Code",
  "version": "0.1.1",
  "private": true,
  "publisher": "neolitec",
  "author": "neolitec",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neolitec/claude-switcher.git"
  },
  "bugs": {
    "url": "https://github.com/neolitec/claude-switcher/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "worktree",
    "terminal"
  ],
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20"
  },
  "packageManager": "pnpm@10.6.2",
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "claudeSwitcher.sessions",
          "name": "Claude Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeSwitcher.refresh",
        "title": "Claude Switcher: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeSwitcher.previewSession",
        "title": "Claude Switcher: Preview Session"
      },
      {
        "command": "claudeSwitcher.activateSession",
        "title": "Claude Switcher: Resume Session",
        "icon": "$(play)"
      },
      {
        "command": "claudeSwitcher.activateWorktreeLatest",
        "title": "Claude Switcher: Resume Latest Session",
        "icon": "$(play)"
      },
      {
        "command": "claudeSwitcher.createSession",
        "title": "Claude Switcher: Start New Session",
        "icon": "$(add)"
      },
      {
        "command": "claudeSwitcher.showHistory",
        "title": "Claude Switcher: Expanded View (show history)",
        "icon": "$(list-tree)"
      },
      {
        "command": "claudeSwitcher.hideHistory",
        "title": "Claude Switcher: Simplified View",
        "icon": "$(list-flat)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeSwitcher.showHistory",
          "when": "view == claudeSwitcher.sessions && !claudeSwitcher.historyVisible",
          "group": "navigation@1"
        },
        {
          "command": "claudeSwitcher.hideHistory",
          "when": "view == claudeSwitcher.sessions && claudeSwitcher.historyVisible",
          "group": "navigation@1"
        },
        {
          "command": "claudeSwitcher.refresh",
          "when": "view == claudeSwitcher.sessions",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeSwitcher.activateWorktreeLatest",
          "when": "view == claudeSwitcher.sessions && viewItem =~ /^worktree(-root)?$/",
          "group": "inline"
        },
        {
          "command": "claudeSwitcher.createSession",
          "when": "view == claudeSwitcher.sessions && (viewItem =~ /-root$/ || viewItem == worktree-empty)",
          "group": "inline"
        },
        {
          "command": "claudeSwitcher.activateSession",
          "when": "view == claudeSwitcher.sessions && viewItem == session",
          "group": "inline"
        },
        {
          "command": "claudeSwitcher.previewSession",
          "when": "view == claudeSwitcher.sessions && viewItem == session",
          "group": "1_preview"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "lint": "eslint src",
    "knip": "knip",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test out/test/*.test.js",
    "pretest": "tsc -p tsconfig.test.json",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "tsc -p ./",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "knip": "^6.24.0",
    "prettier": "^3.9.4",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.1"
  }
}
